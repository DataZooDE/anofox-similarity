# name: test/sql/cold_start_analogs.test
# description: Tests for cold_start_analogs() table function - finds similar materials with consumption history
# group: [sql]

require anofox_similarity

statement ok
PRAGMA enable_verification

# Load synthetic test data
statement ok
CREATE TABLE materials AS SELECT * FROM read_csv_auto('test/data/synthetic/materials.csv');

statement ok
CREATE TABLE bom_items AS SELECT * FROM read_csv_auto('test/data/synthetic/bom_items.csv');

statement ok
CREATE TABLE goods_movements AS SELECT * FROM read_csv_auto('test/data/synthetic/goods_movements.csv');

# ============================================================================
# Basic functionality tests
# ============================================================================

# Find analogs for a new product (IDENT-PROD-A)
# IDENT-PROD-B is identical (similarity=1.0) and has 23 months history
# (Jan 2022 to Dec 2023 = 23 months difference)
query TRRIITT
SELECT material_id, ROUND(similarity, 4), shared_components, total_components,
       history_months, first_usage, last_usage
FROM cold_start_analogs('IDENT-PROD-A', 5, min_history_months := 12)
WHERE material_id = 'IDENT-PROD-B';
----
IDENT-PROD-B	1.0	5	5	23	2022-01-15	2023-12-15

# ============================================================================
# History filtering tests
# ============================================================================

# Products with less than min_history_months should be excluded
# OVLP-PROD-B has only 6 months history - should NOT appear when requiring 12 months
query I
SELECT COUNT(*)
FROM cold_start_analogs('OVLP-PROD-A', 100, min_history_months := 12)
WHERE material_id = 'OVLP-PROD-B';
----
0

# But OVLP-PROD-B SHOULD appear when requiring only 3 months
query I
SELECT COUNT(*)
FROM cold_start_analogs('OVLP-PROD-A', 100, min_history_months := 3)
WHERE material_id = 'OVLP-PROD-B';
----
1

# ============================================================================
# Self-exclusion test
# ============================================================================

# Query material should NOT appear in results even if it has history
query I
SELECT COUNT(*)
FROM cold_start_analogs('IDENT-PROD-A', 100, min_history_months := 0)
WHERE material_id = 'IDENT-PROD-A';
----
0

# ============================================================================
# Ordering tests
# ============================================================================

# Results should be ordered by similarity descending (like find_similar_materials)
query I
WITH results AS (
    SELECT similarity, ROW_NUMBER() OVER () as rn
    FROM cold_start_analogs('FAMILY-00-BASE', 10, min_history_months := 0)
)
SELECT CASE
    WHEN (SELECT COUNT(*) FROM results r1, results r2 WHERE r1.rn < r2.rn AND r1.similarity < r2.similarity) = 0
    THEN 1
    ELSE 0
END AS correctly_ordered;
----
1

# ============================================================================
# k limit test
# ============================================================================

# Should return at most k results
query I
SELECT COUNT(*)
FROM cold_start_analogs('FAMILY-00-BASE', 3, min_history_months := 0);
----
3

# ============================================================================
# Combined similarity and history test
# ============================================================================

# Find materials similar to FAMILY-00-BASE with at least 12 months history
# VAR-1 (similarity 0.8182) has 18 months
# VAR-2 (similarity 0.5385) has 24 months
# VAR-3 (similarity 0.3333) has 6 months (should be excluded)
query TR rowsort
SELECT material_id, ROUND(similarity, 4)
FROM cold_start_analogs('FAMILY-00-BASE', 10, min_history_months := 12)
WHERE material_id LIKE 'FAMILY-00-VAR-%';
----
FAMILY-00-VAR-1	0.8182
FAMILY-00-VAR-2	0.5385

# ============================================================================
# Custom table parameter test
# ============================================================================

# Create custom goods movements table
statement ok
CREATE TABLE custom_movements AS
SELECT * FROM goods_movements WHERE material_id LIKE 'IDENT-%';

# Using custom movements table should work
query I
SELECT COUNT(*)
FROM cold_start_analogs('IDENT-PROD-A', 5, min_history_months := 12,
                        movements_table := 'custom_movements');
----
1

# ============================================================================
# Edge cases
# ============================================================================

# Material with no similar products that have history
# Create a product with unique components
statement ok
INSERT INTO bom_items VALUES
    ('BOM-UNIQUE', 'UNIQUE-PROD', 'UNIQUE-COMP-1', 1.0, 1, 10),
    ('BOM-UNIQUE', 'UNIQUE-PROD', 'UNIQUE-COMP-2', 1.0, 1, 20);

statement ok
INSERT INTO materials VALUES
    ('UNIQUE-PROD', 'Unique Product', 'GRP-99', 'FERT', '2024-01-01'),
    ('UNIQUE-COMP-1', 'Unique Component 1', 'GRP-99', 'HALB', '2024-01-01'),
    ('UNIQUE-COMP-2', 'Unique Component 2', 'GRP-99', 'HALB', '2024-01-01');

# No results expected with min_similarity > 0.0 - no component overlap with other products
query I
SELECT COUNT(*)
FROM cold_start_analogs('UNIQUE-PROD', 10, min_history_months := 0, min_similarity := 0.01);
----
0

