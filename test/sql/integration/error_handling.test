# ============================================================================
# Test 5: BOM Traversal with Circular References (Depth Limit Protection)
# ============================================================================

# Create circular BOM structure
statement ok
CREATE TABLE circular_bom (parent_id VARCHAR, child_id VARCHAR, quantity FLOAT)

statement ok
INSERT INTO circular_bom VALUES
    ('A', 'B', 1.0),
    ('B', 'C', 1.0),
    ('C', 'A', 1.0)  -- Creates cycle

# Depth-limited traversal should not infinite loop
# Test with depth limit of 5 levels (should handle cycle gracefully)
statement ok
CREATE MACRO test_dfs_neighborhood() AS TABLE
WITH RECURSIVE dfs(component, depth) AS (
    SELECT DISTINCT child_id AS component, 0 AS depth
    FROM circular_bom
    WHERE parent_id = 'A'
    UNION ALL
    SELECT DISTINCT cb.child_id AS component, dfs.depth + 1
    FROM dfs
    INNER JOIN circular_bom cb ON dfs.component = cb.parent_id
    WHERE dfs.depth < 5
)
SELECT DISTINCT component FROM dfs

# Should complete without infinite loop (depth limit prevents infinite recursion)
query I
SELECT COUNT(*) >= 1 FROM test_dfs_neighborhood()
----
1

# ============================================================================
# Test 6: WL Kernel Similarity with Non-existent Materials
# ============================================================================

# Create minimal BOM for testing
statement ok
CREATE TABLE test_wl_bom (parent_id VARCHAR, child_id VARCHAR)

statement ok
INSERT INTO test_wl_bom VALUES ('MAT-A', 'COMP-1'), ('MAT-B', 'COMP-2')

# WL kernel similarity with non-existent material should handle gracefully (return NULL or 0)
query I
SELECT CASE
    WHEN result IS NULL OR (result >= 0.0 AND result <= 1.0) THEN 1
    ELSE 0
END
FROM (
    SELECT wl_kernel_similarity('MAT-NONEXISTENT-1', 'MAT-NONEXISTENT-2', iterations := 3, bom_table := 'test_wl_bom') AS result
)
----
1

