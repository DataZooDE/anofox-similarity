# ============================================================================
# Test 8: Jaccard Similarity with Empty BOMs
# ============================================================================

# Create empty BOM structure
statement ok
CREATE TABLE empty_test_bom (parent_id VARCHAR, child_id VARCHAR)

# Jaccard similarity with empty arrays should return 0.0
query I
SELECT CASE
    WHEN result = 0.0 THEN 1
    ELSE 0
END
FROM (
    SELECT jaccard_similarity([]::VARCHAR[], []::VARCHAR[]) AS result
)
----
1

