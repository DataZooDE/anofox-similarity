# name: test/sql/scenarios/s4_variant_clusters.test
# description: S4 - Variant clusters with 90%, 70%, 50% retention should show decreasing similarity
# group: [scenarios]

# tier: tier1

require anofox_similarity

statement ok
PRAGMA enable_verification

# Load synthetic test data
statement ok
CREATE TABLE materials AS SELECT * FROM read_csv_auto('test/data/synthetic/materials.csv.gz');

statement ok
CREATE TABLE bom_items AS SELECT * FROM read_csv_auto('test/data/synthetic/bom_items.csv.gz');

statement ok
CREATE TABLE ground_truth AS SELECT * FROM read_csv_auto('test/data/synthetic/ground_truth.csv.gz');

# Verify FAMILY-00 test data (one product family)
query I
SELECT COUNT(*) FROM materials WHERE material_id LIKE 'FAMILY-00-%';
----
23

# Base product should have 10 components
query I
SELECT COUNT(DISTINCT child_id)
FROM bom_items
WHERE parent_id = 'FAMILY-00-BASE';
----
10

# Each variant should have 10 components
query III
SELECT
    (SELECT COUNT(DISTINCT child_id) FROM bom_items WHERE parent_id = 'FAMILY-00-VAR-1') AS var1,
    (SELECT COUNT(DISTINCT child_id) FROM bom_items WHERE parent_id = 'FAMILY-00-VAR-2') AS var2,
    (SELECT COUNT(DISTINCT child_id) FROM bom_items WHERE parent_id = 'FAMILY-00-VAR-3') AS var3;
----
10	10	10

# Calculate Jaccard for BASE vs VAR-1 (90% retention) using jaccard_similarity
# Expected: 9 shared / (10 + 10 - 9) = 9/11 = 0.8182
query R
SELECT ROUND(jaccard_similarity(
    (SELECT list(child_id) FROM bom_items WHERE parent_id = 'FAMILY-00-BASE'),
    (SELECT list(child_id) FROM bom_items WHERE parent_id = 'FAMILY-00-VAR-1')
), 4);
----
0.8182

# Calculate Jaccard for BASE vs VAR-2 (70% retention) using jaccard_similarity
# Expected: 7 shared / (10 + 10 - 7) = 7/13 = 0.5385
query R
SELECT ROUND(jaccard_similarity(
    (SELECT list(child_id) FROM bom_items WHERE parent_id = 'FAMILY-00-BASE'),
    (SELECT list(child_id) FROM bom_items WHERE parent_id = 'FAMILY-00-VAR-2')
), 4);
----
0.5385

# Calculate Jaccard for BASE vs VAR-3 (50% retention) using jaccard_similarity
# Expected: 5 shared / (10 + 10 - 5) = 5/15 = 0.3333
query R
SELECT ROUND(jaccard_similarity(
    (SELECT list(child_id) FROM bom_items WHERE parent_id = 'FAMILY-00-BASE'),
    (SELECT list(child_id) FROM bom_items WHERE parent_id = 'FAMILY-00-VAR-3')
), 4);
----
0.3333

# Verify ordering: sim(BASE, VAR-1) > sim(BASE, VAR-2) > sim(BASE, VAR-3)
query I
WITH base_components AS (
    SELECT list(child_id) AS components FROM bom_items WHERE parent_id = 'FAMILY-00-BASE'
),
jaccard_scores AS (
    SELECT
        'VAR-1' AS variant,
        jaccard_similarity(
            (SELECT components FROM base_components),
            (SELECT list(child_id) FROM bom_items WHERE parent_id = 'FAMILY-00-VAR-1')
        ) AS score
    UNION ALL
    SELECT
        'VAR-2',
        jaccard_similarity(
            (SELECT components FROM base_components),
            (SELECT list(child_id) FROM bom_items WHERE parent_id = 'FAMILY-00-VAR-2')
        )
    UNION ALL
    SELECT
        'VAR-3',
        jaccard_similarity(
            (SELECT components FROM base_components),
            (SELECT list(child_id) FROM bom_items WHERE parent_id = 'FAMILY-00-VAR-3')
        )
)
SELECT
    CASE
        WHEN (SELECT score FROM jaccard_scores WHERE variant = 'VAR-1') >
             (SELECT score FROM jaccard_scores WHERE variant = 'VAR-2')
        AND (SELECT score FROM jaccard_scores WHERE variant = 'VAR-2') >
            (SELECT score FROM jaccard_scores WHERE variant = 'VAR-3')
        THEN 1
        ELSE 0
    END AS ordering_correct;
----
1

# Verify ground truth values
query RT rowsort
SELECT material_b, ROUND(expected_similarity, 4)
FROM ground_truth
WHERE material_a = 'FAMILY-00-BASE'
ORDER BY expected_similarity DESC;
----
FAMILY-00-VAR-1	0.8182
FAMILY-00-VAR-2	0.5385
FAMILY-00-VAR-3	0.3333
