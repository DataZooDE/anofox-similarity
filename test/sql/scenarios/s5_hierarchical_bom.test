# name: test/sql/scenarios/s5_hierarchical_bom.test
# tier: tier1
# description: S5 - Multi-level BOM structure with sub-assemblies
# group: [tier1_synthetic]

require anofox_similarity

statement ok
PRAGMA enable_verification

# Load synthetic test data
statement ok
CREATE TABLE materials AS SELECT * FROM read_csv_auto('test/data/synthetic/materials.csv.gz');

statement ok
CREATE TABLE bom_items AS SELECT * FROM read_csv_auto('test/data/synthetic/bom_items.csv.gz');

statement ok
CREATE TABLE ground_truth AS SELECT * FROM read_csv_auto('test/data/synthetic/ground_truth.csv.gz');

# Verify hierarchical test data loaded
query I
SELECT COUNT(*) FROM materials WHERE material_id LIKE 'HIER-%';
----
18

# Verify structure: 12 leaf components + 3 sub-assemblies + 3 products = 18

# Verify sub-assemblies have 4 leaf components each
query III
SELECT
    (SELECT COUNT(DISTINCT child_id) FROM bom_items WHERE parent_id = 'HIER-SUBASM-A') AS subasm_a,
    (SELECT COUNT(DISTINCT child_id) FROM bom_items WHERE parent_id = 'HIER-SUBASM-B') AS subasm_b,
    (SELECT COUNT(DISTINCT child_id) FROM bom_items WHERE parent_id = 'HIER-SUBASM-C') AS subasm_c;
----
4	4	4

# Verify products have 2 sub-assemblies each
query III
SELECT
    (SELECT COUNT(DISTINCT child_id) FROM bom_items WHERE parent_id = 'HIER-PROD-1') AS prod1,
    (SELECT COUNT(DISTINCT child_id) FROM bom_items WHERE parent_id = 'HIER-PROD-2') AS prod2,
    (SELECT COUNT(DISTINCT child_id) FROM bom_items WHERE parent_id = 'HIER-PROD-3') AS prod3;
----
2	2	2

# Verify product compositions
# HIER-PROD-1: uses HIER-SUBASM-A, HIER-SUBASM-B
query T rowsort
SELECT child_id FROM bom_items WHERE parent_id = 'HIER-PROD-1' ORDER BY child_id;
----
HIER-SUBASM-A
HIER-SUBASM-B

# HIER-PROD-2: uses HIER-SUBASM-A, HIER-SUBASM-C
query T rowsort
SELECT child_id FROM bom_items WHERE parent_id = 'HIER-PROD-2' ORDER BY child_id;
----
HIER-SUBASM-A
HIER-SUBASM-C

# HIER-PROD-3: uses HIER-SUBASM-B, HIER-SUBASM-C
query T rowsort
SELECT child_id FROM bom_items WHERE parent_id = 'HIER-PROD-3' ORDER BY child_id;
----
HIER-SUBASM-B
HIER-SUBASM-C

# Calculate Jaccard at level 1 (direct children only) using jaccard_similarity
# PROD-1 vs PROD-2: share SUBASM-A, unique {A,B,C} = 3 total, Jaccard = 1/3
query R
SELECT ROUND(jaccard_similarity(
    (SELECT list(child_id) FROM bom_items WHERE parent_id = 'HIER-PROD-1'),
    (SELECT list(child_id) FROM bom_items WHERE parent_id = 'HIER-PROD-2')
), 4);
----
0.3333

# PROD-1 vs PROD-3: share SUBASM-B, Jaccard = 1/3
query R
SELECT ROUND(jaccard_similarity(
    (SELECT list(child_id) FROM bom_items WHERE parent_id = 'HIER-PROD-1'),
    (SELECT list(child_id) FROM bom_items WHERE parent_id = 'HIER-PROD-3')
), 4);
----
0.3333

# PROD-2 vs PROD-3: share SUBASM-C, Jaccard = 1/3
query R
SELECT ROUND(jaccard_similarity(
    (SELECT list(child_id) FROM bom_items WHERE parent_id = 'HIER-PROD-2'),
    (SELECT list(child_id) FROM bom_items WHERE parent_id = 'HIER-PROD-3')
), 4);
----
0.3333

# Calculate deep Jaccard (flatten BOM to leaf level) using jaccard_similarity
# This would be useful when WL kernel is implemented
# PROD-1 has leaf components from SUBASM-A (0-3) and SUBASM-B (4-7) = 8 leaves
# PROD-2 has leaf components from SUBASM-A (0-3) and SUBASM-C (8-11) = 8 leaves
# Intersection: SUBASM-A leaves (0-3) = 4, Union: 12, Jaccard = 4/12 = 1/3
query R
WITH RECURSIVE flattened AS (
    SELECT parent_id AS root, parent_id, child_id, 1 AS depth
    FROM bom_items WHERE parent_id LIKE 'HIER-PROD-%'
    UNION ALL
    SELECT f.root, b.parent_id, b.child_id, f.depth + 1
    FROM flattened f JOIN bom_items b ON f.child_id = b.parent_id
    WHERE f.depth < 3
),
leaves AS (
    SELECT DISTINCT root, child_id FROM flattened
    WHERE child_id NOT IN (SELECT DISTINCT parent_id FROM bom_items WHERE parent_id LIKE 'HIER-%')
),
prod1_leaves AS (SELECT list(DISTINCT child_id) AS components FROM leaves WHERE root = 'HIER-PROD-1'),
prod2_leaves AS (SELECT list(DISTINCT child_id) AS components FROM leaves WHERE root = 'HIER-PROD-2')
SELECT ROUND(jaccard_similarity(
    (SELECT components FROM prod1_leaves),
    (SELECT components FROM prod2_leaves)
), 4) AS deep_jaccard;
----
0.3333

# Verify ground truth
query RT rowsort
SELECT material_b, ROUND(expected_similarity, 4)
FROM ground_truth
WHERE material_a LIKE 'HIER-PROD-%'
ORDER BY material_a, material_b;
----
HIER-PROD-2	0.3333
HIER-PROD-3	0.3333
HIER-PROD-3	0.3333
