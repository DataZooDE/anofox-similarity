# name: test/sql/fusion/similarity_methods.test
# tier: tier2
# description: Test find_similar_materials Jaccard similarity search
# group: [fusion]

require anofox_similarity

# ============================================================================
# Test 1: Setup - Create test BOM data
# ============================================================================

statement ok
CREATE TEMP TABLE test_boms AS
SELECT * FROM (VALUES
    ('MAT-001', 'COMP-A'),
    ('MAT-001', 'COMP-B'),
    ('MAT-001', 'COMP-C'),
    ('MAT-002', 'COMP-A'),
    ('MAT-002', 'COMP-B'),
    ('MAT-002', 'COMP-D'),
    ('MAT-003', 'COMP-X'),
    ('MAT-003', 'COMP-Y'),
    ('MAT-004', 'COMP-A'),
    ('MAT-004', 'COMP-B'),
    ('MAT-004', 'COMP-C')
) AS t(parent_id, child_id);

# ============================================================================
# Test 2: Verify find_similar_materials returns correct count
# ============================================================================

query III
SELECT COUNT(*) as found, MIN(similarity)::FLOAT as min_sim, MAX(similarity)::FLOAT as max_sim
FROM find_similar_materials_jaccard('MAT-001', 5, bom_table := 'test_boms')
WHERE material_id != 'MAT-001';
----
3
0.0
1.0

# ============================================================================
# Test 3: Verify identical BOM gives similarity = 1.0
# ============================================================================

# MAT-001 and MAT-004 have identical components {A, B, C}
query I
SELECT ROUND(similarity, 2) = 1.0
FROM find_similar_materials_jaccard('MAT-001', 5, bom_table := 'test_boms')
WHERE material_id = 'MAT-004';
----
true

# ============================================================================
# Test 4: Verify partial overlap gives expected Jaccard
# ============================================================================

# MAT-001 vs MAT-002: shared {A,B}, union {A,B,C,D} = 2/4 = 0.5
query I
SELECT ROUND(similarity, 2) = 0.5
FROM find_similar_materials_jaccard('MAT-001', 5, bom_table := 'test_boms')
WHERE material_id = 'MAT-002';
----
true

# ============================================================================
# Test 5: Verify disjoint BOMs give similarity = 0
# ============================================================================

# MAT-001 vs MAT-003: no shared components
query I
SELECT similarity = 0.0
FROM find_similar_materials_jaccard('MAT-001', 5, bom_table := 'test_boms')
WHERE material_id = 'MAT-003';
----
true

# ============================================================================
# Test 6: Verify min_similarity filtering
# ============================================================================

# Only MAT-004 should pass with min_similarity >= 0.9
query I
SELECT COUNT(*)
FROM find_similar_materials_jaccard('MAT-001', 5, min_similarity := 0.9, bom_table := 'test_boms');
----
1

# ============================================================================
# Test 7: Verify k parameter limits results
# ============================================================================

query I
SELECT COUNT(*)
FROM find_similar_materials_jaccard('MAT-001', 2, bom_table := 'test_boms');
----
2

# ============================================================================
# Test 8: Verify results are ordered by similarity descending
# ============================================================================

query I
WITH results AS (
    SELECT similarity, ROW_NUMBER() OVER () as rn
    FROM find_similar_materials_jaccard('MAT-001', 5, bom_table := 'test_boms')
),
ordering_check AS (
    SELECT COUNT(*) as violations
    FROM results r1, results r2
    WHERE r1.rn < r2.rn AND r1.similarity < r2.similarity
)
SELECT violations = 0 FROM ordering_check;
----
true

# ============================================================================
# Test 9: Verify shared_components and total_components are returned
# ============================================================================

query I
SELECT shared_components IS NOT NULL AND total_components IS NOT NULL
FROM find_similar_materials_jaccard('MAT-001', 1, bom_table := 'test_boms');
----
true

# ============================================================================
# Test 10: WL kernel should be called directly
# ============================================================================

# wl_kernel_similarity can be called directly for graph-based similarity
query I
SELECT wl_kernel_similarity('MAT-001', 'MAT-004', bom_table := 'test_boms') >= 0;
----
true
