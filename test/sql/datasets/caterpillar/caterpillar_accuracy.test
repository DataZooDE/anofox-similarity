# name: test/sql/datasets/caterpillar/caterpillar_accuracy.test
# tier: tier2
# description: Accuracy metrics on Caterpillar industrial tube assembly dataset (21K assemblies)
# group: [accuracy, caterpillar]

# Validates Jaccard similarity accuracy on Caterpillar Tube Pricing dataset:
# - 19,149 tube assemblies (FERT) with 2,048 component types
# - Wide variety of similarity levels from identical to unrelated
# - Ground truth: 140 identical, 20 partial_overlap, 20 low_overlap, 20 unrelated
#
# Note: find_similar_materials macro has a known issue with this dataset due to
# DuckDB macro binding. Direct Jaccard queries work correctly.

require anofox_similarity

statement ok
PRAGMA enable_verification

# ============================================================================
# Setup: Load Caterpillar dataset
# ============================================================================

statement ok
CREATE TABLE materials AS SELECT * FROM read_csv_auto('test/data/caterpillar/materials.csv.gz');

statement ok
CREATE TABLE bom_items AS SELECT * FROM read_csv_auto('test/data/caterpillar/bom_items.csv.gz');

statement ok
CREATE TABLE ground_truth AS SELECT * FROM read_csv_auto('test/data/caterpillar/ground_truth.csv.gz');

# ============================================================================
# Verify dataset loaded correctly
# ============================================================================

# Total materials (tubes + components)
query I
SELECT COUNT(*) FROM materials;
----
21197

# Tube assemblies (FERT = finished goods)
query I
SELECT COUNT(*) FROM materials WHERE material_type = 'FERT';
----
19149

# Components (ROH = raw materials)
query I
SELECT COUNT(*) FROM materials WHERE material_type = 'ROH';
----
2048

# BOM items
query I
SELECT COUNT(*) FROM bom_items;
----
39459

# ============================================================================
# Verify ground truth loaded
# ============================================================================

# Should have 200 ground truth pairs total
query I
SELECT COUNT(*) FROM ground_truth;
----
200

# Identical pairs (Jaccard = 1.0)
query I
SELECT COUNT(*) FROM ground_truth WHERE relationship_type = 'identical';
----
140

# Partial overlap pairs
query I
SELECT COUNT(*) FROM ground_truth WHERE relationship_type = 'partial_overlap';
----
20

# Low overlap pairs
query I
SELECT COUNT(*) FROM ground_truth WHERE relationship_type = 'low_overlap';
----
20

# Unrelated pairs (Jaccard = 0.0)
query I
SELECT COUNT(*) FROM ground_truth WHERE relationship_type = 'unrelated';
----
20

# ============================================================================
# Ground Truth Jaccard Validation
# ============================================================================

# Identical pairs should have Jaccard = 1.0
query R
SELECT ROUND(AVG(jaccard_similarity(
    (SELECT list(child_id) FROM bom_items WHERE parent_id = g.material_a),
    (SELECT list(child_id) FROM bom_items WHERE parent_id = g.material_b)
)), 2)
FROM ground_truth g
WHERE relationship_type = 'identical';
----
1.0

# Unrelated pairs should have Jaccard = 0.0
query R
SELECT ROUND(AVG(jaccard_similarity(
    (SELECT list(child_id) FROM bom_items WHERE parent_id = g.material_a),
    (SELECT list(child_id) FROM bom_items WHERE parent_id = g.material_b)
)), 2)
FROM ground_truth g
WHERE relationship_type = 'unrelated';
----
0.0

# Partial overlap should have similarity between 0.5 and 0.8
query I
SELECT AVG(jaccard_similarity(
    (SELECT list(child_id) FROM bom_items WHERE parent_id = g.material_a),
    (SELECT list(child_id) FROM bom_items WHERE parent_id = g.material_b)
)) BETWEEN 0.5 AND 0.85
FROM ground_truth g
WHERE relationship_type = 'partial_overlap';
----
true

# Low overlap should have similarity between 0.2 and 0.5
query I
SELECT AVG(jaccard_similarity(
    (SELECT list(child_id) FROM bom_items WHERE parent_id = g.material_a),
    (SELECT list(child_id) FROM bom_items WHERE parent_id = g.material_b)
)) BETWEEN 0.15 AND 0.5
FROM ground_truth g
WHERE relationship_type = 'low_overlap';
----
true

# ============================================================================
# Similarity ordering: identical > partial > low > unrelated
# ============================================================================

query I
WITH jaccard_by_type AS (
    SELECT
        relationship_type,
        AVG(jaccard_similarity(
            (SELECT list(child_id) FROM bom_items WHERE parent_id = g.material_a),
            (SELECT list(child_id) FROM bom_items WHERE parent_id = g.material_b)
        )) as avg_jaccard
    FROM ground_truth g
    GROUP BY relationship_type
)
SELECT
    (SELECT avg_jaccard FROM jaccard_by_type WHERE relationship_type = 'identical') >
    (SELECT avg_jaccard FROM jaccard_by_type WHERE relationship_type = 'partial_overlap')
    AND
    (SELECT avg_jaccard FROM jaccard_by_type WHERE relationship_type = 'partial_overlap') >
    (SELECT avg_jaccard FROM jaccard_by_type WHERE relationship_type = 'low_overlap')
    AND
    (SELECT avg_jaccard FROM jaccard_by_type WHERE relationship_type = 'low_overlap') >
    (SELECT avg_jaccard FROM jaccard_by_type WHERE relationship_type = 'unrelated');
----
true

# ============================================================================
# Specific tube assembly validation
# ============================================================================

# Test a known identical pair: TA-00030 and TA-06911 share 2 components
query R
SELECT jaccard_similarity(
    (SELECT list(child_id) FROM bom_items WHERE parent_id = 'TA-00030'),
    (SELECT list(child_id) FROM bom_items WHERE parent_id = 'TA-06911')
);
----
1.0

# Test a known partial overlap pair
query I
SELECT jaccard_similarity(
    (SELECT list(child_id) FROM bom_items WHERE parent_id = 'TA-02868'),
    (SELECT list(child_id) FROM bom_items WHERE parent_id = 'TA-13776')
) BETWEEN 0.7 AND 0.8;
----
true

# ============================================================================
# Component aggregation validation
# ============================================================================

# aggregate_material_components should work correctly
query I
SELECT COUNT(*) > 0 FROM aggregate_material_components();
----
true

# Each tube should have 1-8 components (Caterpillar BOM format)
query I
WITH comp_counts AS (
    SELECT material_id, len(components) as num_comp
    FROM aggregate_material_components()
)
SELECT bool_and(num_comp BETWEEN 1 AND 8) FROM comp_counts;
----
true

# ============================================================================
# Direct similarity ranking (workaround for find_similar_materials)
# ============================================================================

# For a query tube, verify identical tubes have similarity = 1.0
query I
WITH mc AS (
    SELECT * FROM aggregate_material_components()
),
query_comp AS (
    SELECT components FROM mc WHERE material_id = 'TA-00030'
),
similarities AS (
    SELECT
        mc.material_id,
        jaccard_similarity((SELECT components FROM query_comp), mc.components) as sim
    FROM mc
    WHERE mc.material_id != 'TA-00030'
)
SELECT COUNT(*) >= 1 FROM similarities WHERE sim = 1.0;
----
true

# Top similar tubes should have high similarity
query I
WITH mc AS (
    SELECT * FROM aggregate_material_components()
),
query_comp AS (
    SELECT components FROM mc WHERE material_id = 'TA-00030'
),
similarities AS (
    SELECT
        mc.material_id,
        jaccard_similarity((SELECT components FROM query_comp), mc.components) as sim
    FROM mc
    WHERE mc.material_id != 'TA-00030'
    ORDER BY sim DESC
    LIMIT 10
)
SELECT AVG(sim) >= 0.5 FROM similarities;
----
true

# ============================================================================
# Average Jaccard validation for ground truth quality
# ============================================================================

# Non-unrelated ground truth pairs should have positive Jaccard
query I
WITH jaccard_scores AS (
    SELECT jaccard_similarity(
        (SELECT list(child_id) FROM bom_items WHERE parent_id = g.material_a),
        (SELECT list(child_id) FROM bom_items WHERE parent_id = g.material_b)
    ) as jaccard
    FROM ground_truth g
    WHERE relationship_type != 'unrelated'
)
SELECT AVG(jaccard) >= 0.60 FROM jaccard_scores;
----
true
