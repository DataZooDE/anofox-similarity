# name: test/sql/datasets/caterpillar/caterpillar_scale.test
# description: Scale testing with 21K tube assemblies
# group: [caterpillar]

# tier: tier2

# Tests scalability characteristics on the largest BOM dataset:
# - 19,149 tube assemblies
# - Validates that Jaccard similarity scales to industrial workloads
#
# Note: find_similar_materials macro has a known issue with this dataset.
# This test uses direct Jaccard queries instead.

require anofox_similarity

statement ok
PRAGMA enable_verification

# ============================================================================
# Setup: Load Caterpillar dataset
# ============================================================================

statement ok
CREATE TABLE materials AS SELECT * FROM read_csv_auto('test/data/caterpillar/materials.csv.gz');

statement ok
CREATE TABLE bom_items AS SELECT * FROM read_csv_auto('test/data/caterpillar/bom_items.csv.gz');

# ============================================================================
# Validate dataset scale
# ============================================================================

query I
SELECT COUNT(*) FROM materials WHERE material_type = 'FERT';
----
19149

query I
SELECT COUNT(*) FROM bom_items;
----
39459

# ============================================================================
# Test aggregate_material_components at scale
# ============================================================================

# Should aggregate all tube assemblies
query I
SELECT COUNT(*) FROM aggregate_material_components();
----
19149

# ============================================================================
# Test Jaccard similarity at scale
# ============================================================================

# Compute similarity for a sample tube - should find matches
query I
WITH mc AS (
    SELECT * FROM aggregate_material_components()
),
query_comp AS (
    SELECT components FROM mc WHERE material_id = 'TA-00030'
),
similarities AS (
    SELECT
        mc.material_id,
        jaccard_similarity((SELECT components FROM query_comp), mc.components) as sim
    FROM mc
    WHERE mc.material_id != 'TA-00030'
    ORDER BY sim DESC
    LIMIT 10
)
SELECT COUNT(*) FROM similarities;
----
10

# Results should be ordered by descending similarity
query I
WITH mc AS (
    SELECT * FROM aggregate_material_components()
),
query_comp AS (
    SELECT components FROM mc WHERE material_id = 'TA-00030'
),
similarities AS (
    SELECT
        mc.material_id,
        jaccard_similarity((SELECT components FROM query_comp), mc.components) as sim
    FROM mc
    WHERE mc.material_id != 'TA-00030'
    ORDER BY sim DESC
    LIMIT 20
),
ranked AS (
    SELECT
        sim,
        LAG(sim) OVER () as prev_sim
    FROM similarities
)
SELECT COUNT(*) = 0 FROM ranked WHERE prev_sim IS NOT NULL AND sim > prev_sim;
----
true

# ============================================================================
# Test min_similarity filtering with direct queries
# ============================================================================

# With high threshold, should get results (caterpillar has many identical tubes)
# Note: TA-00030 has 2 components shared by 1484+ other tubes
query I
WITH mc AS (
    SELECT * FROM aggregate_material_components()
),
query_comp AS (
    SELECT components FROM mc WHERE material_id = 'TA-00030'
),
similarities AS (
    SELECT
        mc.material_id,
        jaccard_similarity((SELECT components FROM query_comp), mc.components) as sim
    FROM mc
    WHERE mc.material_id != 'TA-00030'
)
SELECT COUNT(*) > 0 FROM similarities WHERE sim >= 0.5;
----
true

# With threshold = 1.0, should only get exact matches
query I
WITH mc AS (
    SELECT * FROM aggregate_material_components()
),
query_comp AS (
    SELECT components FROM mc WHERE material_id = 'TA-00030'
),
similarities AS (
    SELECT
        mc.material_id,
        jaccard_similarity((SELECT components FROM query_comp), mc.components) as sim
    FROM mc
    WHERE mc.material_id != 'TA-00030'
)
SELECT bool_and(sim = 1.0) FROM similarities WHERE sim = 1.0;
----
true

# ============================================================================
# Scale test: Query multiple tubes
# ============================================================================

# Query 10 tubes and verify results for each
query I
WITH sample_tubes AS (
    SELECT material_id FROM materials
    WHERE material_type = 'FERT'
    ORDER BY material_id
    LIMIT 10
),
mc AS (
    SELECT * FROM aggregate_material_components()
),
similarity_results AS (
    SELECT
        st.material_id as query_tube,
        (SELECT COUNT(*) FROM mc m
         WHERE m.material_id != st.material_id) as candidate_count
    FROM sample_tubes st
)
SELECT bool_and(candidate_count > 0) FROM similarity_results;
----
true

# ============================================================================
# Component diversity validation
# ============================================================================

# Verify we have diverse component types
query I
SELECT COUNT(DISTINCT material_group) >= 10
FROM materials
WHERE material_type = 'ROH';
----
true

# ============================================================================
# BOM structure validation
# ============================================================================

# Average components per tube
query I
SELECT AVG(comp_count)::INTEGER BETWEEN 1 AND 10
FROM (
    SELECT parent_id, COUNT(*) as comp_count
    FROM bom_items
    GROUP BY parent_id
);
----
true

# Maximum components in a single tube (Caterpillar has up to 8 slots)
query I
SELECT MAX(comp_count) <= 8
FROM (
    SELECT parent_id, COUNT(*) as comp_count
    FROM bom_items
    GROUP BY parent_id
);
----
true

# ============================================================================
# High similarity pairs exist
# ============================================================================

# There should be tubes with identical composition (similarity = 1.0)
query I
WITH mc AS (
    SELECT * FROM aggregate_material_components()
),
query_comp AS (
    SELECT components FROM mc WHERE material_id = 'TA-00030'
)
SELECT COUNT(*) > 0 FROM mc
WHERE mc.material_id != 'TA-00030'
  AND jaccard_similarity((SELECT components FROM query_comp), mc.components) = 1.0;
----
true
