# name: test/sql/datasets/sap/sap_embedding_validation.test
# tier: tier3
# description: Validate min-hash embedding generation on real SAP data
# group: [sap]

require anofox_similarity

# ============================================================================
# Setup Phase: Load Real SAP Data
# ============================================================================

# Ensure parquet extension is loaded
statement ok
INSTALL parquet;

statement ok
LOAD parquet;

# Load SAP tables from parquet files
statement ok
CREATE TEMP TABLE sap_mara AS
SELECT * FROM read_parquet('test/data/sap/mara.parquet');

statement ok
CREATE TEMP TABLE sap_stko AS
SELECT * FROM read_parquet('test/data/sap/stko.parquet');

statement ok
CREATE TEMP TABLE sap_mast AS
SELECT * FROM read_parquet('test/data/sap/mast.parquet');

statement ok
CREATE TEMP TABLE sap_stpo AS
SELECT * FROM read_parquet('test/data/sap/stpo.parquet');

statement ok
CREATE TEMP TABLE sap_makt AS
SELECT * FROM read_parquet('test/data/sap/makt.parquet');

# ============================================================================
