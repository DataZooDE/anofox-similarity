# name: test/sql/datasets/erp_systems/erp_integration.test
# tier: tier2
# description: Validate similarity functions on ERP system datasets
# group: [integration, erp]

# Tests that the canonical schema works correctly across multiple ERP sources:
# - Odoo: 50 materials, 18 BOM items (open source ERP)
# - ERPNext: 18 materials, 8 BOM items (open source ERP)
# - PDXpert: 62 materials, 64 BOM items (PLM system)
# - Neo4j: 25 materials, 47 BOM items (graph database sample)
#
# All datasets use the same canonical schema:
# - materials.csv.gz: material_id, description, material_group, material_type, created_date
# - bom_items.csv.gz: bom_id, parent_id, child_id, quantity, level, position

require anofox_similarity

statement ok
PRAGMA enable_verification

# ============================================================================
# Test 1: Odoo Dataset
# ============================================================================

statement ok
CREATE SCHEMA odoo;

statement ok
CREATE TABLE odoo.materials AS SELECT * FROM read_csv_auto('test/data/odoo/materials.csv.gz');

statement ok
CREATE TABLE odoo.bom_items AS SELECT * FROM read_csv_auto('test/data/odoo/bom_items.csv.gz');

statement ok
CREATE TABLE odoo.ground_truth AS SELECT * FROM read_csv_auto('test/data/odoo/ground_truth.csv.gz');

# Verify Odoo dataset size
query I
SELECT COUNT(*) FROM odoo.materials;
----
50

query I
SELECT COUNT(*) FROM odoo.bom_items;
----
18

query I
SELECT COUNT(*) FROM odoo.ground_truth;
----
21

# Odoo Jaccard validation for ground truth
query I
WITH jaccard_scores AS (
    SELECT jaccard_similarity(
        (SELECT list(child_id) FROM odoo.bom_items WHERE parent_id = g.material_a),
        (SELECT list(child_id) FROM odoo.bom_items WHERE parent_id = g.material_b)
    ) as jaccard
    FROM odoo.ground_truth g
)
SELECT COUNT(*) >= 0 FROM jaccard_scores WHERE jaccard >= 0;
----
true

