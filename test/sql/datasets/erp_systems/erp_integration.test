# ============================================================================
# Cross-dataset schema validation
# ============================================================================

# All datasets should have same columns in materials table
query I
WITH odoo_cols AS (SELECT column_name FROM duckdb_columns() WHERE table_name = 'materials' AND schema_name = 'odoo'),
erpnext_cols AS (SELECT column_name FROM duckdb_columns() WHERE table_name = 'materials' AND schema_name = 'erpnext'),
pdxpert_cols AS (SELECT column_name FROM duckdb_columns() WHERE table_name = 'materials' AND schema_name = 'pdxpert')
SELECT COUNT(*) = 5 FROM odoo_cols;
----
true

# All datasets should have same columns in bom_items table
query I
SELECT COUNT(*) = 6 FROM duckdb_columns() WHERE table_name = 'bom_items' AND schema_name = 'odoo';
----
true

# ============================================================================
# Combined statistics
# ============================================================================

# Total materials across all ERP datasets
query I
SELECT
    (SELECT COUNT(*) FROM odoo.materials) +
    (SELECT COUNT(*) FROM erpnext.materials) +
    (SELECT COUNT(*) FROM pdxpert.materials) +
    (SELECT COUNT(*) FROM neo4j.materials);
----
155

# Total BOM items across all ERP datasets
query I
SELECT
    (SELECT COUNT(*) FROM odoo.bom_items) +
    (SELECT COUNT(*) FROM erpnext.bom_items) +
    (SELECT COUNT(*) FROM pdxpert.bom_items) +
    (SELECT COUNT(*) FROM neo4j.bom_items);
----
137

# ============================================================================
# Jaccard similarity works on all datasets
# ============================================================================

# Odoo: jaccard_similarity works
query I
WITH odoo_mc AS (
    SELECT parent_id as material_id, list(child_id ORDER BY child_id) as components
    FROM odoo.bom_items
    GROUP BY parent_id
)
SELECT jaccard_similarity(a.components, b.components) >= 0
FROM odoo_mc a, odoo_mc b
WHERE a.material_id < b.material_id
LIMIT 1;
----
true

# ERPNext: jaccard_similarity works
query I
WITH erpnext_mc AS (
    SELECT parent_id as material_id, list(child_id ORDER BY child_id) as components
    FROM erpnext.bom_items
    GROUP BY parent_id
)
SELECT jaccard_similarity(a.components, b.components) >= 0
FROM erpnext_mc a, erpnext_mc b
WHERE a.material_id < b.material_id
LIMIT 1;
----
true

# PDXpert: jaccard_similarity works
query I
WITH pdxpert_mc AS (
    SELECT parent_id as material_id, list(child_id ORDER BY child_id) as components
