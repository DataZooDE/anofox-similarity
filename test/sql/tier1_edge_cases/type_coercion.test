# name: test/sql/tier1_edge_cases/type_coercion.test
# description: Test type coercion for component IDs (VARCHAR vs INTEGER)
# group: [tier1_edge_cases]

require anofox_similarity

statement ok
PRAGMA enable_verification

# Test case 1: VARCHAR component IDs (standard case)
statement ok
CREATE TABLE varchar_bom (
    parent_id VARCHAR,
    child_id VARCHAR
);

statement ok
INSERT INTO varchar_bom VALUES
    ('PROD-A', 'COMP-001'),
    ('PROD-A', 'COMP-002'),
    ('PROD-B', 'COMP-001'),
    ('PROD-B', 'COMP-003');

query R
WITH
    comp_a AS (SELECT child_id FROM varchar_bom WHERE parent_id = 'PROD-A'),
    comp_b AS (SELECT child_id FROM varchar_bom WHERE parent_id = 'PROD-B'),
    intersection_set AS (SELECT child_id FROM comp_a INTERSECT SELECT child_id FROM comp_b),
    union_set AS (SELECT child_id FROM comp_a UNION SELECT child_id FROM comp_b)
SELECT
    ROUND((SELECT COUNT(*) FROM intersection_set)::FLOAT /
          NULLIF((SELECT COUNT(*) FROM union_set), 0), 4);
----
0.3333

# Test case 2: INTEGER component IDs (numeric case)
statement ok
CREATE TABLE int_bom (
    parent_id VARCHAR,
    child_id INTEGER
);

statement ok
INSERT INTO int_bom VALUES
    ('PROD-A', 1),
    ('PROD-A', 2),
    ('PROD-B', 1),
    ('PROD-B', 3);

query R
WITH
    comp_a AS (SELECT child_id FROM int_bom WHERE parent_id = 'PROD-A'),
    comp_b AS (SELECT child_id FROM int_bom WHERE parent_id = 'PROD-B'),
    intersection_set AS (SELECT child_id FROM comp_a INTERSECT SELECT child_id FROM comp_b),
    union_set AS (SELECT child_id FROM comp_a UNION SELECT child_id FROM comp_b)
SELECT
    ROUND((SELECT COUNT(*) FROM intersection_set)::FLOAT /
          NULLIF((SELECT COUNT(*) FROM union_set), 0), 4);
----
0.3333

