    ('PROD-A', 'b0eebc99-9c0b-4ef8-bb6d-6bb9bd380a22'),
    ('PROD-B', 'a0eebc99-9c0b-4ef8-bb6d-6bb9bd380a11'),
    ('PROD-B', 'c0eebc99-9c0b-4ef8-bb6d-6bb9bd380a33');

query R
WITH
    comp_a AS (SELECT child_id FROM uuid_bom WHERE parent_id = 'PROD-A'),
    comp_b AS (SELECT child_id FROM uuid_bom WHERE parent_id = 'PROD-B'),
    intersection_set AS (SELECT child_id FROM comp_a INTERSECT SELECT child_id FROM comp_b),
    union_set AS (SELECT child_id FROM comp_a UNION SELECT child_id FROM comp_b)
SELECT
    ROUND((SELECT COUNT(*) FROM intersection_set)::FLOAT /
          NULLIF((SELECT COUNT(*) FROM union_set), 0), 4);
----
0.3333

# Test case 7: Quantity as DECIMAL vs FLOAT
statement ok
CREATE TABLE quantity_test (
    parent_id VARCHAR,
    child_id VARCHAR,
    quantity_decimal DECIMAL(18,6),
    quantity_float FLOAT
);

statement ok
INSERT INTO quantity_test VALUES
    ('PROD-A', 'COMP-1', 1.234567, 1.234567),
    ('PROD-A', 'COMP-2', 2.000000, 2.0);

# Verify quantities stored correctly
query TRTR
SELECT parent_id, child_id, quantity_decimal, ROUND(quantity_float, 6)
FROM quantity_test
ORDER BY child_id;
----
PROD-A	COMP-1	1.234567	1.234567
PROD-A	COMP-2	2.000000	2.0
