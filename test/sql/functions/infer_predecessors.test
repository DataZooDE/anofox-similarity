# name: test/sql/functions/infer_predecessors.test
# description: Tests for infer_predecessors() - S7, S8, S9, S12 scenarios
# group: [functions]

# tier: tier1

require anofox_similarity

statement ok
PRAGMA enable_verification

# Load synthetic test data
statement ok
CREATE TABLE materials AS SELECT * FROM read_csv_auto('test/data/synthetic/materials.csv.gz');

statement ok
CREATE TABLE bom_items AS SELECT * FROM read_csv_auto('test/data/synthetic/bom_items.csv.gz');

statement ok
CREATE TABLE goods_movements AS SELECT * FROM read_csv_auto('test/data/synthetic/goods_movements.csv.gz');

# ============================================================================
# S7: Clear predecessor with anti-correlation
# ============================================================================

# S7-PRED-OLD should be detected as predecessor of S7-PRED-NEW
# High anti-correlation, good similarity (8/12 = 0.6667), proper temporal succession
query I
SELECT COUNT(*) FROM infer_predecessors('S7-PRED-NEW', min_confidence := 0.5, min_similarity := 0.5)
WHERE predecessor_id = 'S7-PRED-OLD';
----
1

# Verify high confidence for S7 predecessor detection
query I
SELECT CASE WHEN confidence > 0.7 THEN 1 ELSE 0 END
FROM infer_predecessors('S7-PRED-NEW', min_confidence := 0.3, min_similarity := 0.5)
WHERE predecessor_id = 'S7-PRED-OLD';
----
1

# Verify strong anti-correlation (negative correlation)
query I
SELECT CASE WHEN correlation < -0.8 THEN 1 ELSE 0 END
FROM infer_predecessors('S7-PRED-NEW', min_confidence := 0.3, min_similarity := 0.5)
WHERE predecessor_id = 'S7-PRED-OLD';
----
1

# ============================================================================
# S8: Gradual phase-out with extended overlap
# ============================================================================

# S8-PHASE-OLD should be detected as predecessor of S8-PHASE-NEW
query I
SELECT COUNT(*) FROM infer_predecessors('S8-PHASE-NEW', min_confidence := 0.4, min_similarity := 0.4)
WHERE predecessor_id = 'S8-PHASE-OLD';
----
1

# S8 should have longer overlap period (more overlapping weeks)
query I
SELECT CASE WHEN overlapping_weeks >= 30 THEN 1 ELSE 0 END
FROM infer_predecessors('S8-PHASE-NEW', min_confidence := 0.3, min_similarity := 0.4)
WHERE predecessor_id = 'S8-PHASE-OLD';
----
1

# ============================================================================
# S9: No predecessor (genuinely new product)
# ============================================================================

# S9-BRAND-NEW has unique components not shared with any other material
# Should return 0 predecessors because no similar materials exist
query I
SELECT COUNT(*) FROM infer_predecessors('S9-BRAND-NEW', min_confidence := 0.1, min_similarity := 0.0);
----
0

# ============================================================================
# S12: Transitive predecessor chain (6 generations)
# ============================================================================

# S12-GEN-01 should detect S12-GEN-00 as its predecessor
query I
SELECT COUNT(*) FROM infer_predecessors('S12-GEN-01', min_confidence := 0.3, min_similarity := 0.4)
WHERE predecessor_id = 'S12-GEN-00';
----
1

# S12-GEN-02 should detect S12-GEN-01 as its direct predecessor
query I
SELECT COUNT(*) FROM infer_predecessors('S12-GEN-02', min_confidence := 0.3, min_similarity := 0.4)
WHERE predecessor_id = 'S12-GEN-01';
----
1

# Later generations should not have distant ancestors as high-confidence predecessors
# S12-GEN-00 should NOT be a high-confidence predecessor of S12-GEN-03
# (transitive relationship, not direct)
query I
SELECT CASE WHEN COUNT(*) = 0 OR MIN(confidence) < 0.5 THEN 1 ELSE 0 END
FROM infer_predecessors('S12-GEN-03', min_confidence := 0.3, min_similarity := 0.3)
WHERE predecessor_id = 'S12-GEN-00';
----
1

# ============================================================================
# Parameter tests
# ============================================================================

# min_similarity filter should work
query I
SELECT COUNT(*) FROM infer_predecessors('S7-PRED-NEW', min_similarity := 0.8);
----
0

# min_confidence filter should work
query I
SELECT COUNT(*) FROM infer_predecessors('S7-PRED-NEW', min_confidence := 0.99, min_similarity := 0.5);
----
0

# ============================================================================
# Error case tests
# ============================================================================

# Non-existent BOM table should produce catalog error
statement error
SELECT * FROM infer_predecessors('S7-PRED-NEW', bom_table := 'nonexistent_bom');
----
Catalog Error

# Non-existent movements table should produce catalog error
statement error
SELECT * FROM infer_predecessors('S7-PRED-NEW', movements_table := 'nonexistent_movements');
----
Catalog Error

# ============================================================================
# Boundary tests
# ============================================================================

# Non-existent material should return empty results (not error)
query I
SELECT COUNT(*) FROM infer_predecessors('NONEXISTENT-MATERIAL-XYZ', min_confidence := 0.1, min_similarity := 0.0);
----
0

# min_similarity = 0.0 should still work (allow all similarities)
query I
SELECT COUNT(*) >= 0 FROM infer_predecessors('S7-PRED-NEW', min_confidence := 0.1, min_similarity := 0.0);
----
true

# min_confidence = 0.0 should still work (allow all confidence levels)
query I
SELECT COUNT(*) >= 0 FROM infer_predecessors('S7-PRED-NEW', min_confidence := 0.0, min_similarity := 0.5);
----
true

