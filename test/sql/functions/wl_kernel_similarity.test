# name: test/sql/functions/wl_kernel_similarity.test
# description: Tests for wl_kernel_similarity() macro function
# tier: tier1
# group: [functions]

require anofox_similarity

statement ok
PRAGMA enable_verification

# Load synthetic test data
statement ok
CREATE TABLE materials AS SELECT * FROM read_csv_auto('test/data/synthetic/materials.csv.gz');

statement ok
CREATE TABLE bom_items AS SELECT * FROM read_csv_auto('test/data/synthetic/bom_items.csv.gz');

# ============================================================================
# Basic Function Tests
# ============================================================================

# Test 1: Function returns a numeric value
query I
SELECT wl_kernel_similarity('IDENT-PROD-A', 'IDENT-PROD-B') IS NOT NULL;
----
true

# Test 2: Self-similarity should always be 1.0
query R
SELECT ROUND(wl_kernel_similarity('IDENT-PROD-A', 'IDENT-PROD-A'), 2);
----
1.0

# Test 3: Identical structures should have similarity = 1.0
query R
SELECT ROUND(wl_kernel_similarity('IDENT-PROD-A', 'IDENT-PROD-B'), 2);
----
1.0

# Test 4: Disjoint products should have similarity = 0.0
query R
SELECT ROUND(wl_kernel_similarity('DISJ-PROD-A', 'DISJ-PROD-B'), 2);
----
0.0

# ============================================================================
# Bounds Tests - WL similarity should always be in [0, 1]
# ============================================================================

# Test 5: Result is bounded [0.0, 1.0]
query I
SELECT wl_kernel_similarity('IDENT-PROD-A', 'FAMILY-00-BASE') >= 0.0
   AND wl_kernel_similarity('IDENT-PROD-A', 'FAMILY-00-BASE') <= 1.0;
----
true

# Test 6: Results are consistent across multiple calls
query I
SELECT ABS(wl_kernel_similarity('IDENT-PROD-A', 'FAMILY-00-BASE')
         - wl_kernel_similarity('IDENT-PROD-A', 'FAMILY-00-BASE')) < 0.0001;
----
true

# ============================================================================
# Parameter Tests - iterations parameter
# ============================================================================

# Test 7: Default iterations (should work without specifying)
query I
SELECT wl_kernel_similarity('FAMILY-00-BASE', 'FAMILY-00-VAR-1') IS NOT NULL;
----
true

# Test 8: Custom iterations = 1 (fewer iterations, less neighborhood info)
query I
SELECT wl_kernel_similarity('FAMILY-00-BASE', 'FAMILY-00-VAR-1', iterations := 1) IS NOT NULL;
----
true

# Test 9: Custom iterations = 3 (default level)
query I
SELECT wl_kernel_similarity('FAMILY-00-BASE', 'FAMILY-00-VAR-1', iterations := 3) IS NOT NULL;
----
true

# Test 10: Custom iterations = 5 (more iterations, larger neighborhood)
query I
SELECT wl_kernel_similarity('FAMILY-00-BASE', 'FAMILY-00-VAR-1', iterations := 5) IS NOT NULL;
----
true

# Test 11: More iterations should generally increase similarity (more neighborhood info shared)
# Note: This is not always true, but for variant families it typically is
query I
WITH iter_sims AS (
    SELECT
        wl_kernel_similarity('FAMILY-00-BASE', 'FAMILY-00-VAR-1', iterations := 1) as iter1,
        wl_kernel_similarity('FAMILY-00-BASE', 'FAMILY-00-VAR-1', iterations := 3) as iter3,
        wl_kernel_similarity('FAMILY-00-BASE', 'FAMILY-00-VAR-1', iterations := 5) as iter5
)
SELECT iter1 IS NOT NULL AND iter3 IS NOT NULL AND iter5 IS NOT NULL FROM iter_sims;
----
true

# ============================================================================
# BOM Table Parameter Tests
# ============================================================================

# Test 12: Default BOM table should work
query I
SELECT wl_kernel_similarity('IDENT-PROD-A', 'IDENT-PROD-B', bom_table := 'bom_items') IS NOT NULL;
----
true

# Test 13: Non-existent BOM table should produce catalog error
statement error
SELECT wl_kernel_similarity('IDENT-PROD-A', 'IDENT-PROD-B', bom_table := 'nonexistent_table');
----
Catalog Error

# ============================================================================
# Symmetry Tests - WL similarity should be symmetric
# ============================================================================

# Test 14: wl_kernel_similarity(A, B) should equal wl_kernel_similarity(B, A)
query I
SELECT ABS(wl_kernel_similarity('IDENT-PROD-A', 'FAMILY-00-BASE')
         - wl_kernel_similarity('FAMILY-00-BASE', 'IDENT-PROD-A')) < 0.0001;
----
true

# Test 15: Symmetry with custom iterations
query I
SELECT ABS(wl_kernel_similarity('FAMILY-00-BASE', 'FAMILY-00-VAR-1', iterations := 3)
         - wl_kernel_similarity('FAMILY-00-VAR-1', 'FAMILY-00-BASE', iterations := 3)) < 0.0001;
----
true

# ============================================================================
# Variant Gradient Tests
# ============================================================================

# Test 16: Variant families should show decreasing WL similarity
# VAR-1 (90% retention) > VAR-2 (70%) > VAR-3 (50%)
query I
WITH variant_sims AS (
    SELECT
        wl_kernel_similarity('FAMILY-00-BASE', 'FAMILY-00-VAR-1') as var1,
        wl_kernel_similarity('FAMILY-00-BASE', 'FAMILY-00-VAR-2') as var2,
        wl_kernel_similarity('FAMILY-00-BASE', 'FAMILY-00-VAR-3') as var3
)
SELECT var1 >= var2 AND var2 >= var3 FROM variant_sims;
----
true

# ============================================================================
# Edge Cases - Non-existent Materials
# ============================================================================

# Test 17: Non-existent material (both) should return NULL or 0.0
query I
SELECT wl_kernel_similarity('NONEXISTENT-A', 'NONEXISTENT-B') IS NULL
    OR wl_kernel_similarity('NONEXISTENT-A', 'NONEXISTENT-B') = 0.0;
----
true

# Test 18: One existent, one non-existent
query I
SELECT wl_kernel_similarity('IDENT-PROD-A', 'NONEXISTENT-MATERIAL') IS NOT NULL;
----
true

# Test 19: Non-existent material should have 0 or very low similarity to existing
query I
SELECT wl_kernel_similarity('IDENT-PROD-A', 'NONEXISTENT-MATERIAL') <= 0.0
    OR wl_kernel_similarity('IDENT-PROD-A', 'NONEXISTENT-MATERIAL') IS NULL;
----
true

# ============================================================================
# Structural Difference Tests - S10 Scenario
# ============================================================================

# Test 20: S10 products have same components, different structure
query I
SELECT COUNT(*) FROM materials WHERE material_id LIKE 'S10-PROD-%';
----
2

# Test 21: S10 self-similarity
query R
SELECT ROUND(wl_kernel_similarity('S10-PROD-LINEAR', 'S10-PROD-LINEAR'), 2);
----
1.0

# Test 22: S10 products have structural difference (not fully similar)
# Same leaf components but different hierarchy (LINEAR vs STAR)
query I
SELECT wl_kernel_similarity('S10-PROD-LINEAR', 'S10-PROD-STAR') > 0
   AND wl_kernel_similarity('S10-PROD-LINEAR', 'S10-PROD-STAR') < 1.0;
----
true

# ============================================================================
# Hierarchy Depth Tests - S11 Scenario
# ============================================================================

# Test 23: S11 products have deep hierarchy
query I
SELECT COUNT(*) FROM bom_items WHERE parent_id LIKE 'S11-L%';
----
12

# Test 24: S11 deep product self-similarity
query I
WITH deep_products AS (
    SELECT DISTINCT parent_id FROM bom_items
    WHERE parent_id LIKE 'S11-PROD-DEEP-%'
    LIMIT 1
)
SELECT wl_kernel_similarity(parent_id, parent_id) = 1.0 FROM deep_products;
----
true

# Test 25: Deep products with shared hierarchy show positive similarity
query I
SELECT wl_kernel_similarity('S11-PROD-DEEP-A', 'S11-PROD-DEEP-B') > 0.0;
----
true

# ============================================================================
# Comparison with Jaccard - WL captures structure
# ============================================================================

# Test 26: WL captures structure beyond simple component overlap
# Both WL and Jaccard should agree on identical products
query I
SELECT ABS(wl_kernel_similarity('IDENT-PROD-A', 'IDENT-PROD-B')
         - jaccard_similarity(
             (SELECT list(child_id) FROM bom_items WHERE parent_id = 'IDENT-PROD-A'),
             (SELECT list(child_id) FROM bom_items WHERE parent_id = 'IDENT-PROD-B')
           )) < 0.0001;
----
true

# ============================================================================
# Return Type Tests
# ============================================================================

# Test 27: Return value is a DOUBLE/REAL
query I
SELECT typeof(wl_kernel_similarity('IDENT-PROD-A', 'IDENT-PROD-B'));
----
DOUBLE

# Test 28: Can use in WHERE clause comparisons
query I
SELECT COUNT(*) FROM (
    SELECT 'IDENT-PROD-A' as mat_id
    WHERE wl_kernel_similarity('IDENT-PROD-A', 'IDENT-PROD-B') > 0.5
);
----
1

# Test 29: Function returns consistent value on repeated calls
query I
SELECT (
    SELECT wl_kernel_similarity('FAMILY-00-BASE', 'FAMILY-00-VAR-1')
) = (
    SELECT wl_kernel_similarity('FAMILY-00-BASE', 'FAMILY-00-VAR-1')
);
----
true
