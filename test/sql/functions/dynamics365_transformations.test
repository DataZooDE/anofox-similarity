# name: test/sql/functions/dynamics365_transformations.test
# description: Dynamics 365 BOM transformations to universal schema
# group: [functions]

# tier: tier1

require anofox_similarity

statement ok
PRAGMA enable_verification

# ============================================================================
# Test 1: Create Dynamics 365 InventTable (materials master)
# ============================================================================

statement ok
CREATE TABLE d365_InventTable AS
SELECT * FROM (VALUES
    ('ITEM-001', 'Assembly 1', 0),      -- ItemId, ItemName, ItemType (0=BOM)
    ('ITEM-002', 'Component 1', 2),     -- ItemType 2 = Component
    ('ITEM-003', 'Component 2', 2)
) AS t(ItemId, ItemName, ItemType)

# ============================================================================
# Test 2: Create Dynamics 365 BOMTable (BOM header)
# ============================================================================

statement ok
CREATE TABLE d365_BOMTable AS
SELECT * FROM (VALUES
    ('BOM-001', 'ITEM-001', 0),         -- BOMId, ItemId, Status (0=Active)
    ('BOM-002', 'ITEM-002', 0)          -- Status 0 = Active
) AS t(BOMId, ItemId, Status)

# ============================================================================
# Test 3: Create Dynamics 365 BOMVersion (BOM version details)
# ============================================================================

statement ok
CREATE TABLE d365_BOMVersion AS
SELECT * FROM (VALUES
    ('BOM-001', 'V1', 1, TIMESTAMP '2024-01-01 00:00:00'),     -- BOMId, VersionId, ApprovedStatus (1=Approved), ActivationDate
    ('BOM-002', 'V1', 0, TIMESTAMP '2024-01-15 00:00:00')      -- ApprovedStatus 0 = Not Approved
) AS t(BOMId, VersionId, ApprovedStatus, ActivationDate)

# ============================================================================
# Test 4: Create Dynamics 365 BOM (BOM components)
# ============================================================================

statement ok
CREATE TABLE d365_BOM AS
SELECT * FROM (VALUES
    ('BOM-001', 1, 'ITEM-002', 2.0, 5.0),   -- BOMId, LineNum, ItemId, Quantity, ScrapPercent
    ('BOM-001', 2, 'ITEM-003', 1.5, 0.0),
    ('BOM-002', 1, 'ITEM-001', 3.0, 10.0)
) AS t(BOMId, LineNum, ItemId, Quantity, ScrapPercent)

# ============================================================================
# Test 5: Test dynamics365_to_materials conversion exists
# ============================================================================

query I
SELECT COUNT(*) > 0 FROM dynamics365_to_materials('d365_InventTable')
----
true

# ============================================================================
# Test 6: Test dynamics365_to_bom_header conversion exists
# ============================================================================

query I
SELECT COUNT(*) > 0 FROM dynamics365_to_bom_header('d365_BOMTable', 'd365_BOMVersion')
----
true

# ============================================================================
# Test 7: Test dynamics365_to_bom_component conversion exists
# ============================================================================

query I
SELECT COUNT(*) > 0 FROM dynamics365_to_bom_component('d365_BOM')
----
true

# ============================================================================
# Test 8: Verify materials count
# ============================================================================

query I
SELECT COUNT(*) FROM dynamics365_to_materials('d365_InventTable')
----
3

# ============================================================================
# Test 9: Verify BOM header count
# ============================================================================

query I
SELECT COUNT(*) FROM dynamics365_to_bom_header('d365_BOMTable', 'd365_BOMVersion')
----
2

# ============================================================================
# Test 10: Verify BOM component count
# ============================================================================

query I
SELECT COUNT(*) FROM dynamics365_to_bom_component('d365_BOM')
----
3

# ============================================================================
# Test 11: Verify active status filtering (only approved BOMs)
# ============================================================================

query I
SELECT COUNT(*) FROM dynamics365_to_bom_header('d365_BOMTable', 'd365_BOMVersion')
WHERE is_approved = TRUE
----
1

# ============================================================================
# Test 12: Verify scrap percentage conversion
# ============================================================================

query I
SELECT COUNT(*) FROM dynamics365_to_bom_component('d365_BOM')
WHERE scrap_percent > 0
----
2

# ============================================================================
# Test 13: Verify component material ID mapping
# ============================================================================

query I
SELECT COUNT(DISTINCT child_material_id) FROM dynamics365_to_bom_component('d365_BOM')
----
3

# ============================================================================
# Test 14: Verify BOM ID preservation
# ============================================================================

query I
SELECT COUNT(DISTINCT bom_id) FROM dynamics365_to_bom_header('d365_BOMTable', 'd365_BOMVersion')
----
2

# ============================================================================
# Test 15: Verify quantity preservation in components
# ============================================================================

query I
SELECT COUNT(*) FROM dynamics365_to_bom_component('d365_BOM')
WHERE quantity_per > 0
----
3
