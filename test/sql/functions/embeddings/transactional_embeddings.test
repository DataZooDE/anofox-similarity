# name: test/sql/functions/embeddings/transactional_embeddings.test
# tier: tier1
# description: Test transactional embedding macro registration (anofox-forecast is soft dependency)
# group: [embeddings]

require anofox_similarity

# ============================================================================
# Test 1: Verify anofox-forecast dependency check macro exists and returns boolean
# ============================================================================

query I
SELECT check_anofox_forecast_available() IN (0, 1);
----
true

# ============================================================================
# Test 2: Verify compute_transactional_embeddings table function is registered
# ============================================================================

statement ok
SELECT COUNT(*) > 0
FROM duckdb_functions()
WHERE function_name = 'compute_transactional_embeddings'
  AND function_type = 'table';

# ============================================================================
# Test Summary: Soft Dependency Validation
# ============================================================================
#
# ✅ Test 1: Dependency check macro exists and works
# ✅ Test 2: Transactional embedding macro is registered
#
# NOTE: Full functional tests with anofox-forecast are skipped in this
# environment because anofox-forecast is a SOFT dependency (not required).
#
# When anofox-forecast is installed via:
#   INSTALL anofox_forecast FROM community;
#   LOAD anofox_forecast;
#
# Users can then call:
#   SELECT * FROM compute_transactional_embeddings('goods_movements');
#
# Feature Sets (when anofox-forecast available):
# - 10 consumption patterns: mean, median, variance, trend, sum, length, etc.
# - 8 demand volatility features: CV, skewness, entropy, etc.
# - 8 frequency domain features: FFT coefficients and aggregates
# - 4 temporal patterns: Autocorrelation at lags 1, 7, 14, 28
# - 98 reserved/zero-padding: For future feature expansion
# Total: 128-D embedding vectors
#
# Integration Path:
# 1. Load extension: LOAD anofox_similarity;
# 2. Install forecast: INSTALL anofox_forecast FROM community;
# 3. Load forecast: LOAD anofox_forecast;
# 4. Generate embeddings: SELECT * FROM compute_transactional_embeddings(...);
# 5. Insert into table: INSERT INTO material_embeddings(...);
# 6. Use in fusion: SELECT * FROM compute_fused_embeddings(...);
#
