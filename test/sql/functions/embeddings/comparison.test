# ============================================================================
# Test 1: Pairwise (Brute-Force) Similarity Baseline
# ============================================================================
#
# Compute pairwise Jaccard similarity for all materials using brute-force.
# This is our ground truth for comparison.

statement ok
CREATE TEMP TABLE pairwise_similarities AS
WITH material_components AS (
    SELECT
        parent_id AS material_id,
        LIST(DISTINCT child_id ORDER BY child_id) AS components
    FROM test_bom_items
    GROUP BY parent_id
),
all_pairs AS (
    SELECT
        a.material_id AS material_a,
        b.material_id AS material_b,
        a.components AS components_a,
        b.components AS components_b
    FROM material_components a
    CROSS JOIN material_components b
    WHERE a.material_id < b.material_id
)
SELECT
    material_a,
    material_b,
    jaccard_similarity(components_a, components_b) AS jaccard_sim,
    array_length(components_a) AS size_a,
    array_length(components_b) AS size_b
FROM all_pairs;

# Verify pairwise similarities computed
query IIII
SELECT COUNT(*), MIN(size_a), MAX(size_a), COUNT(DISTINCT jaccard_sim)
FROM pairwise_similarities;
----
45	2	3	5

# Expected: 45 pairs (10 materials, 10*9/2 pairs)
# Components range from 2-3 in test data
# Unique Jaccard values (identical, partial, disjoint combinations)

# Test 2: Verify known similarities are correct
# PROD-001 vs PROD-008: Should be 1.0 (identical components)
query R
SELECT jaccard_sim
FROM pairwise_similarities
WHERE (material_a = 'PROD-001' AND material_b = 'PROD-008')
   OR (material_a = 'PROD-008' AND material_b = 'PROD-001');
----
1.0

# PROD-001 vs PROD-002: 2/4 = 0.5 (shared: A,B; total: A,B,C,D)
query R
SELECT jaccard_sim
FROM pairwise_similarities
WHERE (material_a = 'PROD-001' AND material_b = 'PROD-002')
   OR (material_a = 'PROD-002' AND material_b = 'PROD-001');
----
0.5

# PROD-001 vs PROD-004: Should be 0.0 (disjoint)
query R
SELECT jaccard_sim
FROM pairwise_similarities
WHERE (material_a = 'PROD-001' AND material_b = 'PROD-004')
   OR (material_a = 'PROD-004' AND material_b = 'PROD-001');
----
0.0

