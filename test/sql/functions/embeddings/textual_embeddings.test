# name: test/sql/functions/embeddings/textual_embeddings.test
# tier: tier1
# description: Test textual embedding generation with DuckDB lambda functions
# group: [embeddings]

require anofox_similarity

# ============================================================================
# Test 1: Verify embedding_backend function exists and is callable
# ============================================================================

statement ok
SELECT embedding_backend('test description', 'gemma-local', '');

# ============================================================================
# Test 2: Verify embedding dimension (384-D)
# ============================================================================

query I
SELECT array_length(
    embedding_backend('test material description', 'gemma-local', ''),
    1
);
----
384

# ============================================================================
# Test 3: Verify embed_text lambda function works
# ============================================================================

query I
SELECT array_length(embed_text('Steel bolt M8x20'), 1);
----
384

# ============================================================================
# Test 4: Verify deterministic embeddings (same input = same output)
# ============================================================================

query I
SELECT CASE WHEN
    embedding_backend('test', 'gemma-local', '') =
    embedding_backend('test', 'gemma-local', '')
THEN 1 ELSE 0 END;
----
1

# ============================================================================
# Test 5: Verify different inputs produce different embeddings
# ============================================================================

query I
SELECT CASE WHEN
    embedding_backend('test1', 'gemma-local', '') !=
    embedding_backend('test2', 'gemma-local', '')
THEN 1 ELSE 0 END;
----
1

# ============================================================================
# Test 6: Batch embedding generation with multiple materials
# ============================================================================

statement ok
CREATE TEMP TABLE test_materials AS
SELECT * FROM (VALUES
    ('MAT-001', 'Steel bolt M8x20'),
    ('MAT-002', 'Aluminum plate 5mm'),
    ('MAT-003', 'Rubber gasket O-ring'),
    ('MAT-004', 'Copper wire 2.5mm'),
    ('MAT-005', 'Plastic fastener')
) AS t(material_id, description);

statement ok
CREATE TEMP TABLE test_embeddings AS
SELECT
    material_id,
    embed_text(description) AS embedding
FROM test_materials;

query I
SELECT COUNT(*) FROM test_embeddings;
----
5

# ============================================================================
# Test 7: Verify all embeddings have correct dimension
# ============================================================================

query I
SELECT COUNT(*) FROM test_embeddings
WHERE array_length(embedding, 1) = 384;
----
5

# ============================================================================
# Test 8: Verify embeddings are non-zero vectors
# ============================================================================

query I
SELECT COUNT(*) FROM test_embeddings
WHERE array_length(embedding, 1) > 0;
----
5

# ============================================================================
# Test 9: Test compute_textual_embeddings macro with mock MAKT data
# ============================================================================

statement ok
CREATE TEMP TABLE mock_makt AS
SELECT * FROM (VALUES
    ('000000000000000001', 'STEEL BOLT', 'M8X20 mm', 'EN'),
    ('000000000000000002', 'ALUMINUM PLATE', '5mm thick', 'EN'),
    ('000000000000000003', 'RUBBER GASKET', 'O-ring shape', 'EN'),
    ('000000000000000004', NULL, 'COPPER WIRE', 'EN'),
    ('000000000000000005', 'PLASTIC FASTENER', NULL, 'EN')
) AS t(matnr, maktx, maktg, spras);

statement ok
CREATE TEMP TABLE computed_embeddings AS
SELECT * FROM compute_textual_embeddings(
    makt_table := 'mock_makt',
    language := 'EN',
    provider := 'gemma-local',
    provider_config := ''
);

query I
SELECT COUNT(*) FROM computed_embeddings;
----
5

# ============================================================================
# Test 10: Verify computed embeddings have correct dimension
# ============================================================================

query I
SELECT COUNT(*) FROM computed_embeddings
WHERE array_length(textual_embedding, 1) = 384;
----
5

# ============================================================================
# Test 11: Verify embeddings are different for different materials
# ============================================================================

query I
SELECT COUNT(DISTINCT textual_embedding) FROM computed_embeddings;
----
5

# ============================================================================
# Test 12: Verify compute_textual_embeddings handles NULL descriptions
# ============================================================================

statement ok
CREATE TEMP TABLE makt_with_nulls AS
SELECT * FROM (VALUES
    ('MAT-001', 'TEST DESC', 'SHORT', 'EN'),
    ('MAT-002', NULL, NULL, 'EN'),
    ('MAT-003', 'ONLY DESC', NULL, 'EN')
) AS t(matnr, maktx, maktg, spras);

statement ok
CREATE TEMP TABLE embeddings_null_handling AS
SELECT * FROM compute_textual_embeddings(
    makt_table := 'makt_with_nulls',
    language := 'EN',
    provider := 'gemma-local',
    provider_config := ''
);

query I
SELECT COUNT(*) FROM embeddings_null_handling;
----
2

# ============================================================================
# Test 13: Verify HTTP provider fallback (basic test)
# ============================================================================

statement ok
SELECT embedding_backend('test', 'openai', '');

# ============================================================================
# Test 14: Verify invalid provider raises error or returns null
# ============================================================================

statement ok
SELECT embedding_backend('test', 'invalid-provider-xyz', '');

# ============================================================================
# Test 15: Batch embedding generation for practical use cases
# ============================================================================

statement ok
CREATE TEMP TABLE practical_materials AS
SELECT * FROM (VALUES
    ('MAT-A', 'Steel component'),
    ('MAT-B', 'Aluminum frame'),
    ('MAT-C', 'Plastic cover')
) AS t(material_id, description);

statement ok
CREATE TEMP TABLE generated_embeddings AS
SELECT
    material_id,
    embed_text(description) AS embedding,
    CURRENT_TIMESTAMP AS generated_at
FROM practical_materials;

query I
SELECT COUNT(*) FROM generated_embeddings
WHERE embedding IS NOT NULL AND array_length(embedding, 1) = 384;
----
3

