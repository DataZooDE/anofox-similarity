# name: test/sql/functions/embeddings/feature_expansion.test
# tier: tier1
# description: Tests for Phase 2B feature expansion (30 → 98 tsfresh features)
# group: [embeddings, feature_expansion]

require anofox_similarity

statement ok
PRAGMA enable_verification

# ============================================================================
# Setup: Initialize test data and statistics tables
# ============================================================================

statement ok
CREATE TEMP TABLE test_goods_movements AS
SELECT * FROM (VALUES
    ('MAT-EXPANSION-A', '2023-01-01'::DATE, 100.0, '261'),
