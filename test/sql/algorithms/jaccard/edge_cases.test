# Test case 4: Mixed numeric strings that look like numbers
statement ok
CREATE TABLE mixed_bom (
    parent_id VARCHAR,
    child_id VARCHAR
);

statement ok
INSERT INTO mixed_bom VALUES
    ('PROD-A', '001'),
    ('PROD-A', '002'),
    ('PROD-B', '1'),
    ('PROD-B', '003');

# '001' and '1' should be treated as different strings
query R
WITH
    comp_a AS (SELECT child_id FROM mixed_bom WHERE parent_id = 'PROD-A'),
    comp_b AS (SELECT child_id FROM mixed_bom WHERE parent_id = 'PROD-B'),
    intersection_set AS (SELECT child_id FROM comp_a INTERSECT SELECT child_id FROM comp_b),
    union_set AS (SELECT child_id FROM comp_a UNION SELECT child_id FROM comp_b)
SELECT
    ROUND((SELECT COUNT(*) FROM intersection_set)::FLOAT /
          NULLIF((SELECT COUNT(*) FROM union_set), 0), 4);
----
0.0

# Test case 5: Case sensitivity for VARCHAR
statement ok
CREATE TABLE case_bom (
    parent_id VARCHAR,
    child_id VARCHAR
);

statement ok
INSERT INTO case_bom VALUES
    ('PROD-A', 'COMP-A'),
    ('PROD-A', 'COMP-B'),
    ('PROD-B', 'comp-a'),
    ('PROD-B', 'COMP-B');

# 'COMP-A' and 'comp-a' should be different (case sensitive)
query R
WITH
    comp_a AS (SELECT child_id FROM case_bom WHERE parent_id = 'PROD-A'),
    comp_b AS (SELECT child_id FROM case_bom WHERE parent_id = 'PROD-B'),
    intersection_set AS (SELECT child_id FROM comp_a INTERSECT SELECT child_id FROM comp_b),
    union_set AS (SELECT child_id FROM comp_a UNION SELECT child_id FROM comp_b)
SELECT
    ROUND((SELECT COUNT(*) FROM intersection_set)::FLOAT /
          NULLIF((SELECT COUNT(*) FROM union_set), 0), 4);
----
0.3333

