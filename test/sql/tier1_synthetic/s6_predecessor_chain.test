# name: test/sql/tier1_synthetic/s6_predecessor_chain.test
# description: S6 - Predecessor chain testing with 70% retention per generation
# group: [tier1_synthetic]

require anofox_similarity

statement ok
PRAGMA enable_verification

# Load synthetic test data
statement ok
CREATE TABLE materials AS SELECT * FROM read_csv_auto('test/data/synthetic/materials.csv');

statement ok
CREATE TABLE bom_items AS SELECT * FROM read_csv_auto('test/data/synthetic/bom_items.csv');

statement ok
CREATE TABLE ground_truth AS SELECT * FROM read_csv_auto('test/data/synthetic/ground_truth.csv');

# Verify predecessor chain data loaded
# 4 products + 10 base components + 3 generations * ~4 new components = ~26
query I
SELECT COUNT(*) FROM materials WHERE material_id LIKE 'PRED-CHAIN-%';
----
26

# Verify 4 generations exist (GEN-00 through GEN-03)
query I
SELECT COUNT(DISTINCT parent_id) FROM bom_items WHERE parent_id LIKE 'PRED-CHAIN-GEN-%';
----
4

# Verify each generation has components
query I
SELECT COUNT(DISTINCT child_id)
FROM bom_items
WHERE parent_id = 'PRED-CHAIN-GEN-00';
----
10

query I
SELECT COUNT(DISTINCT child_id)
FROM bom_items
WHERE parent_id = 'PRED-CHAIN-GEN-01';
----
10

query I
SELECT COUNT(DISTINCT child_id)
FROM bom_items
WHERE parent_id = 'PRED-CHAIN-GEN-02';
----
10

query I
SELECT COUNT(DISTINCT child_id)
FROM bom_items
WHERE parent_id = 'PRED-CHAIN-GEN-03';
----
10

# Calculate Jaccard between adjacent generations (GEN-00 and GEN-01) using jaccard_similarity
# Expected: ~70% retention -> 7 shared / (10+10-7) = 7/13 = 0.5385
query R
SELECT ROUND(jaccard_similarity(
    (SELECT list(child_id) FROM bom_items WHERE parent_id = 'PRED-CHAIN-GEN-00'),
    (SELECT list(child_id) FROM bom_items WHERE parent_id = 'PRED-CHAIN-GEN-01')
), 4);
----
0.5385

# Calculate Jaccard between GEN-01 and GEN-02 using jaccard_similarity
query R
SELECT ROUND(jaccard_similarity(
    (SELECT list(child_id) FROM bom_items WHERE parent_id = 'PRED-CHAIN-GEN-01'),
    (SELECT list(child_id) FROM bom_items WHERE parent_id = 'PRED-CHAIN-GEN-02')
), 4);
----
0.5385

# Calculate Jaccard between GEN-02 and GEN-03 using jaccard_similarity
query R
SELECT ROUND(jaccard_similarity(
    (SELECT list(child_id) FROM bom_items WHERE parent_id = 'PRED-CHAIN-GEN-02'),
    (SELECT list(child_id) FROM bom_items WHERE parent_id = 'PRED-CHAIN-GEN-03')
), 4);
----
0.5385

# Verify similarity decreases for non-adjacent generations (transitive)
# GEN-00 vs GEN-03 should have lower similarity than adjacent pairs
query I
WITH
    gen0_comp AS (SELECT list(child_id) AS components FROM bom_items WHERE parent_id = 'PRED-CHAIN-GEN-00'),
    gen1_comp AS (SELECT list(child_id) AS components FROM bom_items WHERE parent_id = 'PRED-CHAIN-GEN-01'),
    gen3_comp AS (SELECT list(child_id) AS components FROM bom_items WHERE parent_id = 'PRED-CHAIN-GEN-03'),
    adjacent_jaccard AS (
        SELECT jaccard_similarity(
            (SELECT components FROM gen0_comp),
            (SELECT components FROM gen1_comp)
        ) AS score
    ),
    distant_jaccard AS (
        SELECT jaccard_similarity(
            (SELECT components FROM gen0_comp),
            (SELECT components FROM gen3_comp)
        ) AS score
    )
SELECT CASE
    WHEN (SELECT score FROM adjacent_jaccard) > (SELECT score FROM distant_jaccard)
    THEN 1
    ELSE 0
END AS adjacent_more_similar;
----
1

# Verify ground truth for predecessor relationships
query TRT rowsort
SELECT material_a, ROUND(expected_similarity, 4), relationship_type
FROM ground_truth
WHERE relationship_type = 'predecessor'
ORDER BY material_a;
----
PRED-CHAIN-GEN-01	0.5385	predecessor
PRED-CHAIN-GEN-02	0.5385	predecessor
PRED-CHAIN-GEN-03	0.5385	predecessor

# Verify temporal ordering (created_date progresses through generations)
query TT rowsort
SELECT material_id, created_date
FROM materials
WHERE material_id LIKE 'PRED-CHAIN-GEN-%'
ORDER BY material_id;
----
PRED-CHAIN-GEN-00	2020-01-01
PRED-CHAIN-GEN-01	2021-01-01
PRED-CHAIN-GEN-02	2022-01-01
PRED-CHAIN-GEN-03	2023-01-01
