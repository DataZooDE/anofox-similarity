# name: test/sql/tier1_synthetic/s2_disjoint_boms.test
# description: S2 - Disjoint BOMs should have Jaccard similarity of 0.0
# group: [tier1_synthetic]

require anofox_similarity

statement ok
PRAGMA enable_verification

# Load synthetic test data
statement ok
CREATE TABLE materials AS SELECT * FROM read_csv_auto('test/data/synthetic/materials.csv');

statement ok
CREATE TABLE bom_items AS SELECT * FROM read_csv_auto('test/data/synthetic/bom_items.csv');

statement ok
CREATE TABLE ground_truth AS SELECT * FROM read_csv_auto('test/data/synthetic/ground_truth.csv');

# Verify test data loaded correctly
query I
SELECT COUNT(*) FROM materials WHERE material_id LIKE 'DISJ-%';
----
12

# Verify products have correct component counts
query I
SELECT COUNT(DISTINCT child_id)
FROM bom_items
WHERE parent_id = 'DISJ-PROD-A';
----
5

query I
SELECT COUNT(DISTINCT child_id)
FROM bom_items
WHERE parent_id = 'DISJ-PROD-B';
----
5

# Verify there is NO overlap between component sets
query I
SELECT COUNT(*)
FROM (
    SELECT child_id FROM bom_items WHERE parent_id = 'DISJ-PROD-A'
    INTERSECT
    SELECT child_id FROM bom_items WHERE parent_id = 'DISJ-PROD-B'
);
----
0

# Calculate Jaccard similarity using jaccard_similarity function
# For disjoint sets: Jaccard = 0/10 = 0.0
query R
SELECT ROUND(jaccard_similarity(
    (SELECT list(child_id) FROM bom_items WHERE parent_id = 'DISJ-PROD-A'),
    (SELECT list(child_id) FROM bom_items WHERE parent_id = 'DISJ-PROD-B')
), 4);
----
0.0

# Verify ground truth matches
query R
SELECT expected_similarity FROM ground_truth
WHERE material_a = 'DISJ-PROD-A' AND material_b = 'DISJ-PROD-B';
----
0.0
