# R10-CRIT: find_similar_materials_wl_kernel on a dense/complete cyclic BOM must be sub-second
# (set-based UNION), not the old O(nodes^4) UNION ALL blowup. A complete 30-node graph would have
# taken tens of seconds before; it must return k rows quickly now.
statement ok
CREATE TABLE complete_bom AS
SELECT 'C' || a AS parent_id, 'C' || b AS child_id FROM range(30) t1(a), range(30) t2(b) WHERE a <> b;

query I
SELECT COUNT(*) FROM find_similar_materials_wl_kernel('C0', 5, iterations := 1000, bom_table := 'complete_bom');
----
5

statement ok
DROP TABLE complete_bom;

