# ------------------------------------------------------------------------------
# R3-CRIT: fuse_embeddings must not overflow/segfault on a batch large enough that
# count * 768 exceeds the initial list-child capacity.
statement ok
CREATE TEMP TABLE fuse_scale AS
SELECT 'g' || i AS material_id,
       list_resize([1.5]::FLOAT[], 256, 1.5) AS structural_embedding,
       list_resize([2.5]::FLOAT[], 384, 2.5) AS textual_embedding
FROM range(1, 4001) t(i);

query II
SELECT COUNT(*), MAX(len(combined))
FROM (
  SELECT fuse_embeddings(structural_embedding, textual_embedding, NULL::FLOAT[],
     {'structural':0.5,'textual':0.5,'transactional':0.0}) AS combined
  FROM fuse_scale
);
----
4000	768

statement ok
DROP TABLE fuse_scale;

