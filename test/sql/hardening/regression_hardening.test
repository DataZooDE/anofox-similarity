# name: test/sql/hardening/regression_hardening.test
# description: Regression guards for the 2026-07 hardening pass (crashes, scale, defaults, doc drift)
# group: [hardening]

require anofox_similarity

statement ok
PRAGMA enable_verification

# ------------------------------------------------------------------------------
# C-1 / H-1: WL-kernel search must work at scale (previously INTERNAL Error at >=15
# distinct parents) and every score must lie in [0, 1].
# ------------------------------------------------------------------------------
statement ok
CREATE TABLE bom_items AS
SELECT 'M' || i::VARCHAR AS parent_id, 'C' || (i % 40)::VARCHAR AS child_id
FROM range(1, 201) t(i);

# Runs without crashing on 200 parents and returns exactly k rows.
query I
SELECT COUNT(*) FROM find_similar_materials_wl_kernel('M1', 10);
----
10

# All similarities are within [0, 1].
query I
SELECT COUNT(*) FROM find_similar_materials_wl_kernel('M1', 50)
WHERE similarity < 0.0 OR similarity > 1.0;
----
0

statement ok
DROP TABLE bom_items;

# ------------------------------------------------------------------------------
# H-1: wl_kernel_similarity is bounded, symmetric, and self-similarity is 1.0,
# even when a component is reachable at multiple BOM depths (previously returned inf).
# ------------------------------------------------------------------------------
statement ok
CREATE TABLE bom_items(parent_id VARCHAR, child_id VARCHAR);

statement ok
INSERT INTO bom_items VALUES ('A','B'),('A','C'),('B','C'),('B','D'),('X','B'),('X','C'),('X','D'),('C','D');

query I
SELECT wl_kernel_similarity('A','A',3,'bom_items');
----
1.0

# Symmetric and finite, in [0,1].
query I
SELECT CASE WHEN wl_kernel_similarity('A','X',3,'bom_items') = wl_kernel_similarity('X','A',3,'bom_items')
             AND wl_kernel_similarity('A','X',3,'bom_items') BETWEEN 0.0 AND 1.0
        THEN 1 ELSE 0 END;
----
1

# ------------------------------------------------------------------------------
# R2b-CRIT: wl_kernel_similarity with a fixed query and a candidate COLUMN argument (the documented
# pairwise usage) must work at scale, not throw an INTERNAL Error during decorrelation.
statement ok
CREATE TABLE wl_bom AS SELECT 'M' || i::VARCHAR AS parent_id, 'C' || (i % 6)::VARCHAR AS child_id FROM range(1, 40) t(i);

query I
SELECT COUNT(*) FROM (
  SELECT parent_id, wl_kernel_similarity('M1', parent_id, 3, 'wl_bom') AS sim FROM wl_bom
) WHERE sim BETWEEN 0.0 AND 1.0;
----
39

# Self-similarity is 1.0 even when the argument is a column reference.
query I
SELECT COUNT(*) FROM (
  SELECT parent_id, wl_kernel_similarity(parent_id, parent_id, 3, 'wl_bom') AS sim FROM wl_bom
) WHERE sim = 1.0;
----
39

statement ok
DROP TABLE wl_bom;

