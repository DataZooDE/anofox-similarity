# R9-CRIT: multi-path (diamond) BOMs must NOT blow up exponentially. A 25-deep diamond chain with a
# back-edge and a 2-billion max_depth must complete near-instantly (node-based traversal), not hang.
statement ok
CREATE TABLE diamond AS
WITH d AS (SELECT i FROM range(0,25) t(i))
SELECT 'X' || i AS parent_id, 'A' || i AS child_id FROM d
UNION ALL SELECT 'X' || i, 'B' || i FROM d
UNION ALL SELECT 'A' || i, 'X' || (i+1) FROM d
UNION ALL SELECT 'B' || i, 'X' || (i+1) FROM d
UNION ALL SELECT 'X25', 'X0';

query I
SELECT COUNT(*) > 0 FROM bom_dfs_neighborhood(root_material_id := 'X0', max_depth := 2000000000, bom_table := 'diamond');
----
true

statement ok
DROP TABLE diamond;

