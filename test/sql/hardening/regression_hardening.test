# ------------------------------------------------------------------------------
# H-3: previously-phantom functions are now registered.
# ------------------------------------------------------------------------------
query I
SELECT COUNT(*) FROM duckdb_functions()
WHERE function_name IN ('recompute_embedding_statistics', 'compute_domain_specific_statistics');
----
2

# ------------------------------------------------------------------------------
# H-2: fuse_embeddings with a zero-weighted, NULL modality no longer nulls the
# result, and weights that do not sum to 1 are normalized rather than dropped.
# ------------------------------------------------------------------------------
# zero-weighted NULL transactional modality (correct 256/384 dims for the used modalities)
query I
SELECT fuse_embeddings(list_resize([1.0]::FLOAT[], 256, 0.0), list_resize([1.0]::FLOAT[], 384, 0.0),
   NULL::FLOAT[], {'structural':0.5,'textual':0.5,'transactional':0.0}) IS NULL;
----
false

# weights that do not sum to 1 are normalized, not dropped (all three dims correct)
query I
SELECT fuse_embeddings(list_resize([1.0]::FLOAT[], 256, 0.0), list_resize([1.0]::FLOAT[], 384, 0.0),
   list_resize([1.0]::FLOAT[], 128, 0.0), {'structural':0.5,'textual':0.5,'transactional':0.5}) IS NULL;
----
false

# M-3: a wrong-length modality vector at positive weight yields NULL (no silent pad/truncate).
query I
SELECT fuse_embeddings([1.0,2.0]::FLOAT[], list_resize([1.0]::FLOAT[], 384, 0.0),
   list_resize([1.0]::FLOAT[], 128, 0.0), {'structural':0.34,'textual':0.33,'transactional':0.33}) IS NULL;
----
true

