# R11-CRIT: wl_kernel_similarity (via wl_fingerprint) must not blow up exponentially on a dense
# fully-cyclic BOM. Its non-recursive 5-level self-join must dedup at each level (not chain raw
# joins), so cost is O(depth * edges), not O(fanout^depth).
statement ok
CREATE TABLE complete_bom2 AS
SELECT 'M' || a AS parent_id, 'M' || b AS child_id FROM range(80) t1(a), range(80) t2(b) WHERE a <> b;

query I
SELECT wl_kernel_similarity('M0', 'M1', 5, 'complete_bom2') BETWEEN 0.0 AND 1.0;
----
true

statement ok
DROP TABLE complete_bom2;

